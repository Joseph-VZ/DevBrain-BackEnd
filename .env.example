# =====================================================
# DevBrain Backend - Variables de Entorno
# =====================================================

# URL de conexión a la base de datos PostgreSQL.
# Se obtiene desde Supabase (Connect > Direct > URI).
# No subir credenciales reales al repositorio.
#DATABASE_URL= 
#DATABASE_URL=postgresql://postgres:DevBrain2026@@db.DevBrain.supabase.co:5432/postgres


# Clave utilizada para generar y validar los JSON Web Tokens (JWT).
# Se recomienda utilizar una cadena larga y segura.
#JWT_SECRET=
#JWT_SECRET=devbrain_super_secret_2026


# API Key utilizada para la integración con Google Gemini.
# Se obtiene desde Google AI Studio.
#GEMINI_API_KEY=

# Puerto donde se ejecutará el servidor Express.
# En Render normalmente esta variable es asignada automáticamente.
#PORT=3000


DATABASE_URL=postgresql://postgres:DevBrain2026%40@db.seymghutcpgnektyfrjm.supabase.co:5432/postgres
JWT_SECRET=test
PORT=3000